diff --git a/pkg/cloudprovider/drift.go b/pkg/cloudprovider/drift.go
index e14f4c5..07eb779 100644
--- a/pkg/cloudprovider/drift.go
+++ b/pkg/cloudprovider/drift.go
@@ -27,8 +27,9 @@ import (
 )
 
 const (
-	NodeClassDrift cloudprovider.DriftReason = "NodeClassDrift"
-	ImageDrift     cloudprovider.DriftReason = "ImageDrift"
+	NodeClassDrift    cloudprovider.DriftReason = "NodeClassDrift"
+	ImageDrift        cloudprovider.DriftReason = "ImageDrift"
+	ComputeClassDrift cloudprovider.DriftReason = "ComputeClassDrift"
 )
 
 func (c *CloudProvider) isNodeClassDrifted(ctx context.Context, nodeClaim *karpv1.NodeClaim, _ *karpv1.NodePool, nodeClass *v1alpha1.GCENodeClass) cloudprovider.DriftReason {
@@ -42,6 +43,36 @@ func (c *CloudProvider) isNodeClassDrifted(ctx context.Context, nodeClaim *karpv
 		return drifted
 	}
 
+	if drifted := c.isComputeClassDrifted(nodeClaim, nodeClass); drifted != "" {
+		log.FromContext(ctx).Info("compute class drifted", "drifted", drifted)
+		return drifted
+	}
+
+	return ""
+}
+
+// isComputeClassDrifted detects when the ComputeClass reference on a GCENodeClass
+// has changed since the NodeClaim was provisioned. This triggers node replacement
+// so that the new ComputeClass priorities are applied.
+func (c *CloudProvider) isComputeClassDrifted(nodeClaim *karpv1.NodeClaim, nodeClass *v1alpha1.GCENodeClass) cloudprovider.DriftReason {
+	// Get the ComputeClass name that was active when the node was provisioned
+	provisionedCC, hasProvisionedCC := nodeClaim.Annotations[v1alpha1.AnnotationComputeClassName]
+
+	// Get the current ComputeClass reference
+	var currentCC string
+	if nodeClass.Spec.ComputeClassRef != nil {
+		currentCC = nodeClass.Spec.ComputeClassRef.Name
+	}
+
+	// Drift if: CC was added, removed, or changed
+	if hasProvisionedCC && currentCC != provisionedCC {
+		return ComputeClassDrift
+	}
+	if !hasProvisionedCC && currentCC != "" {
+		// ComputeClass was added after provisioning — this is drift
+		return ComputeClassDrift
+	}
+
 	return ""
 }
 
diff --git a/pkg/cloudprovider/drift_test.go b/pkg/cloudprovider/drift_test.go
