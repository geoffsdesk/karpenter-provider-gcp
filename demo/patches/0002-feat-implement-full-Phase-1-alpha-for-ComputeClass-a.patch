diff --git a/cmd/controller/main.go b/cmd/controller/main.go
index fd34753..cfb628f 100644
--- a/cmd/controller/main.go
+++ b/cmd/controller/main.go
@@ -17,7 +17,10 @@ limitations under the License.
 package main
 
 import (
+	"os"
+
 	"github.com/samber/lo"
+	"sigs.k8s.io/controller-runtime/pkg/log"
 	"sigs.k8s.io/karpenter/pkg/cloudprovider/metrics"
 	corecontrollers "sigs.k8s.io/karpenter/pkg/controllers"
 	"sigs.k8s.io/karpenter/pkg/controllers/state"
@@ -26,16 +29,51 @@ import (
 	"github.com/cloudpilot-ai/karpenter-provider-gcp/pkg/cloudprovider"
 	"github.com/cloudpilot-ai/karpenter-provider-gcp/pkg/controllers"
 	"github.com/cloudpilot-ai/karpenter-provider-gcp/pkg/operator"
+	"github.com/cloudpilot-ai/karpenter-provider-gcp/pkg/operator/options"
+	"github.com/cloudpilot-ai/karpenter-provider-gcp/pkg/providers/computeclass"
 )
 
 func main() {
 	ctx, op := operator.NewOperator(coreoperator.NewOperator())
 
+	// Build CloudProvider options based on feature gates
+	var cpOpts []cloudprovider.Option
+
+	opts := options.FromContext(ctx)
+	if opts != nil && opts.EnableComputeClass {
+		logger := log.FromContext(ctx)
+		logger.Info("ComputeClass-aware provisioning is ENABLED (alpha feature)")
+
+		// R4: NAP conflict detection
+		if op.GKEClient != nil {
+			napDetector := computeclass.NewNAPDetector(
+				op.GKEClient,
+				opts.ProjectID,
+				opts.ClusterName,
+				opts.ClusterLocation,
+			)
+			napStatus := napDetector.Detect(ctx)
+			if napStatus.Enabled {
+				logger.Info("WARNING: " + napStatus.Message)
+				if opts.StrictNAPCheck {
+					logger.Error(nil, "FATAL: NAP is enabled and --strict-nap-check is true. "+
+						"Disable NAP before running Karpenter with ComputeClass support.")
+					os.Exit(1)
+				}
+			}
+		}
+
+		// Wire up the ComputeClass provider
+		ccProvider := computeclass.NewDefaultProvider(op.GetClient())
+		cpOpts = append(cpOpts, cloudprovider.WithComputeClassProvider(ccProvider))
+	}
+
 	gcpCloudProvider := cloudprovider.New(
 		op.GetClient(),
 		op.EventRecorder,
 		op.InstanceTypeProvider,
 		op.InstanceProvider,
+		cpOpts...,
 	)
 
 	lo.Must0(op.AddHealthzCheck("cloud-provider", gcpCloudProvider.LivenessProbe))
