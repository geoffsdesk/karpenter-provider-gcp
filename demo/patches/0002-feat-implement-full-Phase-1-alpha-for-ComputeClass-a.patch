+
+package cloudprovider
+
+import (
+	"testing"
+
+	"github.com/stretchr/testify/assert"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	karpv1 "sigs.k8s.io/karpenter/pkg/apis/v1"
+
+	"github.com/cloudpilot-ai/karpenter-provider-gcp/pkg/apis/v1alpha1"
+)
+
+func TestIsComputeClassDrifted(t *testing.T) {
+	cp := &CloudProvider{}
+
+	tests := []struct {
+		name               string
+		nodeClaimAnnotations map[string]string
+		computeClassRef    *v1alpha1.ComputeClassRef
+		expectedDrift      string
+	}{
+		{
+			name: "no drift - no CC on either side",
+			nodeClaimAnnotations: map[string]string{},
+			computeClassRef:    nil,
+			expectedDrift:      "",
+		},
+		{
+			name: "no drift - same CC on both sides",
+			nodeClaimAnnotations: map[string]string{
+				v1alpha1.AnnotationComputeClassName: "cost-optimized",
+			},
+			computeClassRef: &v1alpha1.ComputeClassRef{Name: "cost-optimized"},
+			expectedDrift:   "",
+		},
+		{
+			name: "drift - CC changed",
+			nodeClaimAnnotations: map[string]string{
+				v1alpha1.AnnotationComputeClassName: "cost-optimized",
+			},
+			computeClassRef: &v1alpha1.ComputeClassRef{Name: "performance"},
+			expectedDrift:   string(ComputeClassDrift),
+		},
+		{
+			name: "drift - CC removed",
+			nodeClaimAnnotations: map[string]string{
+				v1alpha1.AnnotationComputeClassName: "cost-optimized",
+			},
+			computeClassRef: nil,
+			expectedDrift:   string(ComputeClassDrift),
+		},
+		{
+			name: "drift - CC added after provisioning",
+			nodeClaimAnnotations: map[string]string{},
+			computeClassRef:    &v1alpha1.ComputeClassRef{Name: "cost-optimized"},
+			expectedDrift:      string(ComputeClassDrift),
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			nodeClaim := &karpv1.NodeClaim{
+				ObjectMeta: metav1.ObjectMeta{
+					Annotations: tt.nodeClaimAnnotations,
+				},
+			}
+			nodeClass := &v1alpha1.GCENodeClass{
+				Spec: v1alpha1.GCENodeClassSpec{
+					ComputeClassRef: tt.computeClassRef,
+				},
+			}
+
+			result := cp.isComputeClassDrifted(nodeClaim, nodeClass)
+			assert.Equal(t, tt.expectedDrift, string(result))
+		})
+	}
+}
