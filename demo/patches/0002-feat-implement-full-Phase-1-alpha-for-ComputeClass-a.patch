+
+func TestNAPStatus_Fields(t *testing.T) {
+	// Test that NAPStatus correctly carries detection results
+	tests := []struct {
+		name     string
+		status   NAPStatus
+		enabled  bool
+		hasMsg   bool
+	}{
+		{
+			name:    "NAP enabled",
+			status:  NAPStatus{Enabled: true, Message: "NAP is enabled"},
+			enabled: true,
+			hasMsg:  true,
+		},
+		{
+			name:    "NAP not enabled",
+			status:  NAPStatus{Enabled: false, Message: "NAP is not enabled"},
+			enabled: false,
+			hasMsg:  true,
+		},
+		{
+			name:    "detection failed",
