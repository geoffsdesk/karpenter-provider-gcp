+
+package computeclass
+
+import (
+	"context"
+	"fmt"
+
+	containerpb "cloud.google.com/go/container/apiv1/containerpb"
+	container "cloud.google.com/go/container/apiv1"
+	"sigs.k8s.io/controller-runtime/pkg/log"
+)
+
+// NAPDetector checks whether Node Auto-Provisioning (NAP) is enabled on a GKE cluster.
+// Karpenter and NAP are mutually exclusive autoscalers; running both simultaneously
+// causes double-provisioning, resource contention, and unpredictable behavior.
+type NAPDetector struct {
+	gkeClient   *container.ClusterManagerClient
+	projectID   string
+	clusterName string
+	location    string
+}
+
+// NewNAPDetector creates a new NAP detector for the given cluster.
+func NewNAPDetector(gkeClient *container.ClusterManagerClient, projectID, clusterName, location string) *NAPDetector {
+	return &NAPDetector{
+		gkeClient:   gkeClient,
+		projectID:   projectID,
+		clusterName: clusterName,
+		location:    location,
+	}
+}
+
+// NAPStatus contains the result of a NAP detection check.
+type NAPStatus struct {
+	// Enabled is true if NAP is enabled on the cluster.
+	Enabled bool
+	// Message provides human-readable context about the NAP state.
+	Message string
+}
+
+// Detect checks the GKE cluster's autoscaling configuration to determine if NAP is enabled.
+// Returns NAPStatus with the detection result. Errors are logged but not fatal —
+// detection failure should not prevent Karpenter from starting.
+func (d *NAPDetector) Detect(ctx context.Context) NAPStatus {
+	logger := log.FromContext(ctx).WithValues(
+		"projectID", d.projectID,
+		"cluster", d.clusterName,
+		"location", d.location,
+	)
+
+	clusterName := fmt.Sprintf("projects/%s/locations/%s/clusters/%s",
+		d.projectID, d.location, d.clusterName)
+
+	req := &containerpb.GetClusterRequest{
+		Name: clusterName,
+	}
+
+	cluster, err := d.gkeClient.GetCluster(ctx, req)
+	if err != nil {
+		logger.Error(err, "failed to query GKE cluster for NAP status, skipping detection")
+		return NAPStatus{
+			Enabled: false,
+			Message: fmt.Sprintf("NAP detection failed (cluster query error): %v", err),
+		}
+	}
+
+	if cluster.Autoscaling != nil && cluster.Autoscaling.EnableNodeAutoprovisioning {
+		logger.Info("WARNING: Node Auto-Provisioning (NAP) is enabled on this cluster. " +
+			"Running Karpenter alongside NAP causes competing autoscaling behavior. " +
+			"Disable NAP or set --strict-nap-check=true to fail on startup.")
+		return NAPStatus{
+			Enabled: true,
+			Message: "NAP is enabled. Karpenter and NAP are mutually exclusive autoscalers. " +
+				"Disable NAP to avoid double-provisioning.",
+		}
+	}
+
+	logger.V(1).Info("NAP is not enabled on this cluster")
+	return NAPStatus{
+		Enabled: false,
+		Message: "NAP is not enabled",
+	}
+}
